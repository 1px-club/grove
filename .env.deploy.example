# 部署配置
# 复制为 .env.deploy 后按实际值修改

SERVER_IP=你的公网IP
SERVER_USER=ubuntu
SSH_PORT=22
PROJECT_PATH=/home/ubuntu/grove

# 远端命令是否默认使用 sudo。Ubuntu 轻量服务器建议保留 1。
REMOTE_SUDO=1

# 本地 Docker 构建平台。Apple Silicon 部署到腾讯云 x86_64 时建议保留 linux/amd64。
DOCKER_PLATFORM=linux/amd64

# 发布前是否在本地执行格式、Lint 和类型检查。
DEPLOY_CHECKS=1
